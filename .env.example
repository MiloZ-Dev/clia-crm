# Base URL of the FastAPI backend
VITE_API_URL=http://localhost:8000

# Anthropic API key used by the Chat page (browser-side calls to the Claude API)
# WARNING: keys exposed in a frontend bundle are visible to end users. Use only
# for local development / trusted environments, or proxy through your backend.
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
